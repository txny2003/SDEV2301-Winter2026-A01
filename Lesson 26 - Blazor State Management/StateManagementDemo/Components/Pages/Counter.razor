@page "/counter"

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Parent Counter Value: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Increment Parent</button>

<CascadingValue Value="currentCount">
    <CounterChild />
</CascadingValue>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
