@page "/products"
@using EfCoreBlazorDemo.Models
@using EfCoreBlazorDemo.Services
@inject ProductService ProductService
@inject IJSRuntime JSRuntime

<h3>Products</h3>

@if (products is null)
{
    <p>Loading...</p>
}
else if (products.Count == 0)
{
    <p>No products yet. Add one below.</p>
}
else
{
    <table class="table">
        <thead>
            <tr><th>Name</th><th>Price</th><th>Sku</th></tr>
        </thead>
        <tbody>
            @foreach (var p in products)
            {
                <tr>
                    <td>@p.Name</td>
                    <td>@p.Price</td>
                    <td>@p.Sku</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary"
                                @onclick="() => BeginEdit(p)">
                            Edit
                        </button>

                        <button class="btn btn-sm btn-outline-danger ms-2"
                                @onclick="() => DeleteProductAsync(p.Id)">
                            Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h4>@(isEditMode ? "Edit Product" : "Add Product")</h4>

@* Instructor note: One form model keeps the demo simple.
   The form binds to formModel whether we're adding or editing. *@
<EditForm Model="formModel" OnValidSubmit="SaveAsync">
    <ValidationSummary />
    <DataAnnotationsValidator />

    <div class="mb-2">
        <label>Name:</label>
        <InputText @bind-Value="formModel.Name" class="form-control" />
        <ValidationMessage For="@(() => formModel.Name)" />
    </div>
    <div class="mb-2">
        <label>Price:</label>
        <InputNumber @bind-Value="formModel.Price" class="form-control" />
        <ValidationMessage For="@(() => formModel.Price)" />
    </div>
    <div class="mb-2">
        <label>Sku:</label>
        <InputText @bind-Value="formModel.Sku" class="form-control" />
        <ValidationMessage For="@(() => formModel.Sku)" />
    </div>

    <button class="btn btn-primary" type="submit">
        @(isEditMode ? "Update" : "Add")
    </button>

    @* type="button" prevents the Cancel button from submitting the form. *@
    @if (isEditMode)
    {
        <button class="btn btn-secondary ms-2"
                type="button"
                @onclick="CancelEdit">
            Cancel
        </button>
    }
</EditForm>

@code {
    private List<Product>? products;

    // Single form model = minimal state + avoids copying edited values between objects.
    private Product formModel = new();

    // Explicit edit mode flag
    private bool isEditMode = false;

    protected override async Task OnInitializedAsync()
    {
        products = await ProductService.ListProductsAsync();
    }

    private async Task SaveAsync()
    {
        // Decide add vs update based on UI state (edit mode).
        if (isEditMode)
        {
            await ProductService.UpdateProductAsync(formModel);
        }
        else
        {
            await ProductService.AddProductAsync(formModel);
        }

        // Refresh list after save.
        products = await ProductService.ListProductsAsync();

        // Reset form to "Add" mode.
        ResetForm();
    }

    private void BeginEdit(Product product)
    {
        // Copy values into the form model.
        // This avoids directly editing the item in the list before Save is clicked.
        formModel = new Product
        {
            Id = product.Id,
            Name = product.Name,
            Price = product.Price,
            Sku = product.Sku
        };

        isEditMode = true;
    }

    private void CancelEdit()
    {
        // Cancel just resets back to "Add" mode.
        ResetForm();
    }

    private async Task DeleteProductAsync(int id)
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>(
            "confirm", "Are you sure you want to delete this item?");

        if (!confirmed)
            return;

        await ProductService.DeleteProductAsync(id);
        products = await ProductService.ListProductsAsync();

        // If we were editing the same product that got deleted, exit edit mode.
        if (isEditMode && formModel.Id == id)
        {
            ResetForm();
        }
    }

    private void ResetForm()
    {
        formModel = new Product();
        isEditMode = false;
    }
}
